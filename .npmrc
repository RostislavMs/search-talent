# pnpm 10+ runs an implicit `pnpm install` before every `pnpm run <script>`
# (verify-deps-before-run). On Windows the supabase CLI postinstall fails
# (it downloads bin/supabase.EXE which pnpm then can't symlink), making
# every `pnpm run dev` exit with code 1 before next can even start.
#
# We already manage builds explicitly in pnpm-workspace.yaml, so skipping
# the pre-flight check is safe.
verify-deps-before-run=false
