NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

NEXT_PUBLIC_APP_URL=

# Supabase service role key — required for admin-side operations such as
# sending follower notifications (used only on the server).
SUPABASE_SERVICE_ROLE_KEY=

# Resend email delivery — optional. If not set, email sending is skipped.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Search Talent <notifications@example.com>"

# GitHub OAuth App — required for the GitHub project auto-sync feature.
# Register the app at https://github.com/settings/developers
# Authorization callback URL must be:
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google Gemini — required for AI-assisted features (e.g. drafting
# GitHub project narrative fields). Get a free-tier key at:
#   https://aistudio.google.com/apikey
# Free tier limits as of 2026: 1500 requests/day on gemini-2.5-flash.
GEMINI_API_KEY=
